# Prometheus URL
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090

# Services Base URL
NEXT_PUBLIC_SERVICES_BASE_URL=http://localhost

# Chaos Monkey API URL
NEXT_PUBLIC_CHAOS_API_URL=http://localhost:3006

# Internal API Key for admin operations
NEXT_PUBLIC_INTERNAL_API_KEY=internal-secret-key

# Service Ports
NEXT_PUBLIC_IDENTITY_PROVIDER_PORT=3001
NEXT_PUBLIC_ORDER_GATEWAY_PORT=3002
NEXT_PUBLIC_STOCK_SERVICE_PORT=3003
NEXT_PUBLIC_KITCHEN_QUEUE_PORT=3004
NEXT_PUBLIC_NOTIFICATION_HUB_PORT=3005
