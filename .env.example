# Environment Configuration Template
# Copy this file to .env and update values

# Internal API Security
INTERNAL_API_KEY=change-this-to-random-secure-key

# Database Credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-this-password
DB_IDENTITY_USER=identity_user
DB_IDENTITY_PASS=change-this-password
DB_ORDERS_USER=orders_user
DB_ORDERS_PASS=change-this-password
DB_INVENTORY_USER=inventory_user
DB_INVENTORY_PASS=change-this-password

# Redis
REDIS_PASSWORD=change-this-password

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=change-this-password

# JWT Configuration
JWT_EXPIRY_ACCESS=15m
JWT_EXPIRY_REFRESH=7d

# Rate Limiting
GLOBAL_RATE_LIMIT=1000
USER_RATE_LIMIT=10
RATE_LIMIT_WINDOW=60000

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password

# Application
NODE_ENV=production
LOG_LEVEL=info
